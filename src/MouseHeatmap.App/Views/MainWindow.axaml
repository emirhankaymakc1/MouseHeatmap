<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:MouseHeatmap.App.ViewModels"
        xmlns:views="using:MouseHeatmap.App.Views"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="740"
        x:Class="MouseHeatmap.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1100" Height="740"
        MinWidth="880" MinHeight="600">

    <TabControl Padding="16">
        <TabItem Header="📊 Dashboard">
            <views:DashboardView DataContext="{Binding Dashboard}" />
        </TabItem>
        <TabItem Header="🔴 Canlı Kayıt">
            <views:LiveView DataContext="{Binding Live}" />
        </TabItem>
        <TabItem Header="🔥 Heatmap">
            <views:HeatmapView DataContext="{Binding Heatmap}" />
        </TabItem>
        <TabItem Header="📈 İstatistikler">
            <views:StatsView DataContext="{Binding Stats}" />
        </TabItem>
        <TabItem Header="🤖 Yapay Zeka Analizi">
            <views:AnalysisView DataContext="{Binding Analysis}" />
        </TabItem>
        <TabItem Header="⚙️ Ayarlar">
            <views:SettingsView DataContext="{Binding Settings}" />
        </TabItem>
        <TabItem Header="ℹ️ Hakkında">
            <views:AboutView />
        </TabItem>
    </TabControl>

</Window>
